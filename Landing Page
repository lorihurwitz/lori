    <div class="t-inner">
      <div class="t-tag">
        <span class="t-category">Social &amp; Creator Infrastructure</span>
        <span class="t-badge soon">Coming Soon</span>
      </div>
      <h3 class="t-title">User-<i>Embedded</i> Social</h3>
      <p class="t-desc">The next consumer social platforms will be built on user-embedded systems where creation generates persistent, compounding value, shifting monetization from attention to ownership.</p>
      <div class="t-cos">
        <span class="t-co">Wabi</span>
        <span class="t-co">Sekai</span>
        <span class="t-co">Mother</span>
      </div>
    </div>
    <div class="t-arrow">&#8594;</div>
  </div>

</section>

